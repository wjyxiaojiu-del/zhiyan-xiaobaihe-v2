.mode-scroll { white-space: nowrap; padding: 20rpx 24rpx; }
.mode-list { display: inline-flex; gap: 12rpx; }
.mode-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 32rpx;
  background: #f1f5f9;
  color: var(--text-light);
}
.mode-btn.active { background: var(--primary); color: #fff; }

.form-item { margin-bottom: 20rpx; }
.label { display: block; font-size: 24rpx; font-weight: 600; color: var(--text-light); margin-bottom: 8rpx; }
.input {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.picker { line-height: 1.6; }

.result-box {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #f0fdfa;
  border-radius: 12rpx;
  border: 2rpx solid #99f6e4;
}
.result-line { font-size: 26rpx; margin-bottom: 8rpx; }
.val { color: var(--primary); font-weight: 700; }
