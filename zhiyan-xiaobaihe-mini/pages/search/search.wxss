.search-box {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
}
.search-input {
  flex: 1;
  padding: 16rpx 24rpx;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 28rpx;
}
.search-btn { flex-shrink: 0; padding: 16rpx 32rpx; }

.result-list { padding: 0 24rpx; }
.result-count { font-size: 24rpx; color: var(--text-muted); margin-bottom: 16rpx; }

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border);
}
.result-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.result-id { font-size: 22rpx; font-weight: 700; color: var(--primary); }
.result-name { font-size: 28rpx; font-weight: 700; }
.result-desc { font-size: 24rpx; color: var(--text-light); margin-bottom: 8rpx; }
.result-snippet {
  font-size: 22rpx;
  color: var(--text-muted);
  background: #f8fafc;
  padding: 12rpx;
  border-radius: 8rpx;
  line-height: 1.6;
}
